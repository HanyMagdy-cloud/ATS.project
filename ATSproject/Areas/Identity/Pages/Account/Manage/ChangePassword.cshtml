@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Change password";

    var today = DateTime.Now.ToString("dddd, dd MMM yyyy");

    var email = User.Identity?.Name ?? "";
    var initials = "ME";
    if (!string.IsNullOrWhiteSpace(email))
    {
        initials = email.Length >= 2 ? ("" + char.ToUpper(email[0]) + char.ToUpper(email[1])) : email.ToUpper();
    }
}

<div class="page-wrap">
    <div class="container">

        <!-- Top bar -->
        <div class="page-topbar">
            <div class="page-title">Account</div>
            <div class="page-right">
                <div>@today</div>
                <div class="avatar-circle">@initials</div>
            </div>
        </div>

        <!-- Header -->
        <div class="section-head">
            <div class="section-left">
                <div class="section-icon">
                    <i class="bi bi-shield-lock"></i>
                </div>
                <div>
                    <h2 class="section-h2">Change Password</h2>
                    <div class="text-muted">Update your password securely.</div>
                </div>
            </div>

            <a asp-page="./Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i>
                <span class="ms-1">Back</span>
            </a>
        </div>

        <div class="row justify-content-center">
            <div class="col-12 col-lg-7">

                <div class="jobs-card">
                    <div class="jobs-card-header">
                        <div class="jobs-title">
                            <i class="bi bi-key"></i>
                            <span>Security</span>
                        </div>
                        <div class="jobs-badge">Password</div>
                    </div>

                    <div class="p-3 p-md-4">
                        <partial name="_StatusMessage" for="StatusMessage" />

                        <form method="post">
                            <div asp-validation-summary="All" class="text-danger mb-3"></div>

                            <div class="row g-3">

                                <div class="col-12">
                                    <label asp-for="Input.OldPassword" class="form-label">Current password</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-unlock"></i></span>
                                        <input asp-for="Input.OldPassword" class="form-control" autocomplete="current-password" />
                                    </div>
                                    <span asp-validation-for="Input.OldPassword" class="text-danger"></span>
                                </div>

                                <div class="col-12 col-lg-6">
                                    <label asp-for="Input.NewPassword" class="form-label">New password</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-key"></i></span>
                                        <input asp-for="Input.NewPassword" class="form-control" autocomplete="new-password" />
                                    </div>
                                    <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
                                    <div class="form-text">
                                        Use a strong password (uppercase, lowercase, number, symbol).
                                    </div>
                                </div>

                                <div class="col-12 col-lg-6">
                                    <label asp-for="Input.ConfirmPassword" class="form-label">Confirm new password</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-check2-circle"></i></span>
                                        <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" />
                                    </div>
                                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                                </div>

                                <div class="col-12 mt-2">
                                    <div class="row g-2">
                                        <div class="col-12 col-sm-6 col-lg-4 d-grid">
                                            <button type="submit" class="btn btn-primary">
                                                <i class="bi bi-save"></i>
                                                <span class="ms-1">Update Password</span>
                                            </button>
                                        </div>

                                        <div class="col-12 col-sm-6 col-lg-4 d-grid">
                                            <a asp-page="./Index" class="btn btn-outline-secondary">
                                                Cancel
                                            </a>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </form>
                    </div>

                </div>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
