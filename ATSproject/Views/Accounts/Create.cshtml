@model ATS_project.Models.Account
@{
    ViewData["Title"] = "Create Company";

    var today = DateTime.Now.ToString("dddd, dd MMM yyyy");

    var email = User.Identity?.Name ?? "";
    var initials = "AD";
    if (!string.IsNullOrWhiteSpace(email))
    {
        initials = email.Length >= 2 ? ("" + char.ToUpper(email[0]) + char.ToUpper(email[1])) : email.ToUpper();
    }
}

<style>
    /* ── Topbar ── */
    .page-topbar {
        height: 64px;
        background: #fff;
        border-bottom: 1px solid #e2e8f0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 2rem;
        margin-bottom: 2rem;
    }

    .page-title {
        font-size: 1.15rem;
        font-weight: 800;
        color: #1e2a3a;
    }

    .page-right {
        display: flex;
        align-items: center;
        gap: 1rem;
        font-size: 0.82rem;
        color: #94a3b8;
        font-weight: 600;
    }

    .avatar-circle {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: linear-gradient(135deg, #4f8ef7, #7c3aed);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-weight: 800;
        font-size: 0.78rem;
        letter-spacing: 0.5px;
    }

    /* ── Page Header ── */
    .page-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.5rem;
        opacity: 0;
        animation: fadeDown 0.5s 0.05s ease forwards;
    }

    .section-icon {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        background: linear-gradient(135deg, #4f8ef7, #1a56db);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 1.4rem;
        box-shadow: 0 4px 12px rgba(79,142,247,0.3);
    }

    .section-h2 {
        font-size: 1.4rem;
        font-weight: 800;
        color: #1e2a3a;
        margin: 0;
        line-height: 1.2;
    }

    .section-sub {
        font-size: 0.82rem;
        color: #94a3b8;
        font-weight: 600;
        margin-top: 2px;
    }

    /* ── Card ── */
    .jobs-card {
        border: none;
        border-radius: 20px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.07);
        overflow: hidden;
        background: #fff;
        opacity: 0;
        animation: fadeUp 0.6s 0.15s cubic-bezier(.34,1.56,.64,1) forwards;
    }

    .jobs-card-header {
        background: linear-gradient(135deg, #4f8ef7 0%, #1a56db 100%);
        padding: 1.2rem 1.6rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: relative;
        overflow: hidden;
    }

        .jobs-card-header::before {
            content: '';
            position: absolute;
            top: -28px;
            right: -28px;
            width: 100px;
            height: 100px;
            border-radius: 50%;
            background: rgba(255,255,255,0.10);
        }

        .jobs-card-header::after {
            content: '';
            position: absolute;
            bottom: -20px;
            left: -15px;
            width: 70px;
            height: 70px;
            border-radius: 50%;
            background: rgba(255,255,255,0.07);
        }

    .jobs-title {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        color: #fff;
        font-size: 1rem;
        font-weight: 800;
        z-index: 1;
    }

        .jobs-title i {
            font-size: 1.2rem;
            opacity: 0.9;
        }

    .jobs-badge {
        background: rgba(255,255,255,0.2);
        color: #fff;
        font-size: 0.75rem;
        font-weight: 800;
        padding: 0.28em 0.85em;
        border-radius: 20px;
        letter-spacing: 0.06em;
        z-index: 1;
    }

    /* ── Form ── */
    .card-form-body {
        padding: 2rem;
    }

    .form-label-custom {
        font-weight: 700;
        font-size: 0.78rem;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        margin-bottom: 0.45rem;
        display: block;
    }

    .input-group-text-custom {
        background: #f1f5f9;
        border: 1.5px solid #e2e8f0;
        border-right: none;
        color: #4f8ef7;
        font-size: 1rem;
        padding: 0.55rem 0.85rem;
        border-radius: 12px 0 0 12px;
        display: flex;
        align-items: center;
    }

    .form-control-styled {
        border: 1.5px solid #e2e8f0;
        border-left: none;
        border-radius: 0 12px 12px 0 !important;
        font-family: inherit;
        font-size: 0.92rem;
        font-weight: 600;
        color: #1e2a3a;
        padding: 0.55rem 0.9rem;
        background: #f8fafc;
        transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
    }

        .form-control-styled:focus {
            border-color: #4f8ef7;
            background: #fff;
            box-shadow: 0 0 0 3px rgba(79,142,247,0.12);
            outline: none;
        }

    .input-group:focus-within .input-group-text-custom {
        border-color: #4f8ef7;
        background: #eff6ff;
        color: #1a56db;
    }

    .form-divider {
        border: none;
        border-top: 1.5px solid #f1f5f9;
        margin: 1.8rem 0 1.5rem;
    }

    /* ── Buttons ── */
    .btn-save {
        background: linear-gradient(135deg, #22c55e, #15803d);
        color: #fff;
        border: none;
        border-radius: 12px;
        padding: 0.6rem 1.5rem;
        font-family: inherit;
        font-weight: 700;
        font-size: 0.92rem;
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        box-shadow: 0 4px 12px rgba(34,197,94,0.3);
        transition: transform 0.2s cubic-bezier(.34,1.56,.64,1), box-shadow 0.2s;
        cursor: pointer;
    }

        .btn-save:hover {
            transform: translateY(-2px) scale(1.03);
            box-shadow: 0 8px 20px rgba(34,197,94,0.4);
            color: #fff;
        }

    .btn-cancel {
        background: #fff;
        color: #64748b;
        border: 1.5px solid #e2e8f0;
        border-radius: 12px;
        padding: 0.6rem 1.3rem;
        font-family: inherit;
        font-weight: 700;
        font-size: 0.92rem;
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        text-decoration: none;
        transition: all 0.2s;
    }

        .btn-cancel:hover {
            background: #f1f5f9;
            color: #1e2a3a;
            border-color: #cbd5e1;
        }

    @@keyframes fadeDown {
        from {
            opacity: 0;
            transform: translateY(-12px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(24px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<div class="page-topbar">
    <div class="page-title">Create Company</div>
    <div class="page-right">
        <div>@today</div>
        <div class="avatar-circle">@initials</div>
    </div>
</div>

<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">

            <!-- Page Header -->
            <div class="page-header">
                <div class="section-icon"><i class="bi bi-building-add"></i></div>
                <div>
                    <h2 class="section-h2">Create New Company</h2>
                    <div class="section-sub">Add a new company account to the system.</div>
                </div>
            </div>

            <!-- Card -->
            <div class="jobs-card">
                <div class="jobs-card-header">
                    <div class="jobs-title">
                        <i class="bi bi-building"></i>
                        <span>Company Details</span>
                    </div>
                    <div class="jobs-badge">New</div>
                </div>

                <div class="card-form-body">
                    <form asp-action="Create" method="post">

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label-custom"></label>
                            <div class="input-group">
                                <span class="input-group-text-custom"><i class="bi bi-building"></i></span>
                                <input asp-for="Name" class="form-control form-control-styled" />
                            </div>
                            <span asp-validation-for="Name" class="text-danger" style="font-size:0.82rem; font-weight:600;"></span>
                        </div>

                        <hr class="form-divider">

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn-save">
                                <i class="bi bi-check-lg"></i> Save
                            </button>
                            <a asp-action="Index" class="btn-cancel">
                                <i class="bi bi-x"></i> Cancel
                            </a>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>
</div>
