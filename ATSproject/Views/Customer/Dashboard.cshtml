@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-4">
    <h2>Customer Dashboard</h2>
    <p class="text-muted">Welcome! This is the customer home page.</p>

    <div class="row g-3 mt-2">
        <div class="col-12 col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Jobs</h5>
                    <p class="card-text">Create and manage job posts.</p>
                    <a class="btn btn-primary" asp-controller="Jobs" asp-action="Index">Go to Jobs</a>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Candidates</h5>
                    <p class="card-text">View applications and candidate info.</p>
                    <a class="btn btn-primary" asp-controller="Candidates" asp-action="Index">Go to Candidates</a>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Kanban</h5>
                    <p class="card-text">Track candidates by stage.</p>
                    <a class="btn btn-primary" asp-controller="Kanban" asp-action="Index">Go to Kanban</a>
                </div>
            </div>
        </div>
    </div>
</div>
