@model ATS_project.Models.CreateAdminUser

@{
    ViewData["Title"] = "Create Admin";

    var today = DateTime.Now.ToString("dddd, dd MMM yyyy");

    var email = User.Identity?.Name ?? "";
    var initials = "AD";
    if (!string.IsNullOrWhiteSpace(email))
    {
        initials = email.Length >= 2 ? ("" + char.ToUpper(email[0]) + char.ToUpper(email[1])) : email.ToUpper();
    }
}

<style>
    /* ── Topbar ── */
    .page-topbar {
        height: 64px;
        background: #fff;
        border-bottom: 1px solid #e2e8f0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 2rem;
        margin-bottom: 2rem;
    }

    .page-title {
        font-size: 1.15rem;
        font-weight: 800;
        color: #1e2a3a;
    }

    .page-right {
        display: flex;
        align-items: center;
        gap: 1rem;
        font-size: 0.82rem;
        color: #94a3b8;
        font-weight: 600;
    }

    .avatar-circle {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: linear-gradient(135deg, #4f8ef7, #7c3aed);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-weight: 800;
        font-size: 0.78rem;
        letter-spacing: 0.5px;
    }

    /* ── Section Head ── */
    .section-head {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.5rem;
        opacity: 0;
        animation: fadeDown 0.5s 0.05s ease forwards;
    }

    .section-left {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .section-icon {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        background: linear-gradient(135deg, #a855f7, #7c3aed);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 1.4rem;
        box-shadow: 0 4px 12px rgba(168,85,247,0.3);
    }

    .section-h2 {
        font-size: 1.4rem;
        font-weight: 800;
        color: #1e2a3a;
        margin: 0;
        line-height: 1.2;
    }

    .section-sub {
        font-size: 0.82rem;
        color: #94a3b8;
        font-weight: 600;
        margin-top: 2px;
    }

    .btn-back {
        background: #fff;
        color: #64748b;
        border: 1.5px solid #e2e8f0;
        border-radius: 12px;
        padding: 0.55rem 1.1rem;
        font-family: inherit;
        font-weight: 700;
        font-size: 0.88rem;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        text-decoration: none;
        transition: all 0.2s;
    }

        .btn-back:hover {
            background: #f1f5f9;
            color: #1e2a3a;
            border-color: #cbd5e1;
        }

    /* ── Card ── */
    .jobs-card {
        border: none;
        border-radius: 20px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.07);
        overflow: hidden;
        background: #fff;
        opacity: 0;
        animation: fadeUp 0.6s 0.15s cubic-bezier(.34,1.56,.64,1) forwards;
    }

    .jobs-card-header {
        background: linear-gradient(135deg, #a855f7 0%, #7c3aed 100%);
        padding: 1.2rem 1.6rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: relative;
        overflow: hidden;
    }

        .jobs-card-header::before {
            content: '';
            position: absolute;
            top: -28px;
            right: -28px;
            width: 100px;
            height: 100px;
            border-radius: 50%;
            background: rgba(255,255,255,0.10);
        }

        .jobs-card-header::after {
            content: '';
            position: absolute;
            bottom: -20px;
            left: -15px;
            width: 70px;
            height: 70px;
            border-radius: 50%;
            background: rgba(255,255,255,0.07);
        }

    .jobs-title {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        color: #fff;
        font-size: 1rem;
        font-weight: 800;
        z-index: 1;
    }

        .jobs-title i {
            font-size: 1.2rem;
            opacity: 0.9;
        }

    .jobs-badge {
        background: rgba(255,255,255,0.2);
        color: #fff;
        font-size: 0.75rem;
        font-weight: 800;
        padding: 0.28em 0.85em;
        border-radius: 20px;
        letter-spacing: 0.06em;
        z-index: 1;
    }

    /* ── Form ── */
    .card-form-body {
        padding: 2rem;
    }

    .form-section-label {
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #cbd5e1;
        margin: 1.6rem 0 1rem;
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

        .form-section-label:first-child {
            margin-top: 0;
        }

        .form-section-label::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #f1f5f9;
        }

    .form-label-custom {
        font-weight: 700;
        font-size: 0.78rem;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        margin-bottom: 0.45rem;
        display: block;
    }

    .input-group-text-custom {
        background: #f1f5f9;
        border: 1.5px solid #e2e8f0;
        border-right: none;
        color: #a855f7;
        font-size: 1rem;
        padding: 0.55rem 0.85rem;
        border-radius: 12px 0 0 12px;
        display: flex;
        align-items: center;
    }

    .form-control-styled {
        border: 1.5px solid #e2e8f0;
        border-left: none;
        border-radius: 0 12px 12px 0 !important;
        font-family: inherit;
        font-size: 0.92rem;
        font-weight: 600;
        color: #1e2a3a;
        padding: 0.55rem 0.9rem;
        background: #f8fafc;
        transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
    }

        .form-control-styled:focus {
            border-color: #a855f7;
            background: #fff;
            box-shadow: 0 0 0 3px rgba(168,85,247,0.12);
            outline: none;
        }

    .input-group:focus-within .input-group-text-custom {
        border-color: #a855f7;
        background: #faf5ff;
        color: #7c3aed;
    }

    .field-hint {
        font-size: 0.78rem;
        color: #94a3b8;
        font-weight: 600;
        margin-top: 0.4rem;
        display: flex;
        align-items: center;
        gap: 0.3rem;
    }

    .form-divider {
        border: none;
        border-top: 1.5px solid #f1f5f9;
        margin: 1.8rem 0 1.5rem;
    }

    /* ── Buttons ── */
    .btn-save {
        background: linear-gradient(135deg, #a855f7, #7c3aed);
        color: #fff;
        border: none;
        border-radius: 12px;
        padding: 0.6rem 1.5rem;
        font-family: inherit;
        font-weight: 700;
        font-size: 0.92rem;
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        box-shadow: 0 4px 12px rgba(168,85,247,0.3);
        transition: transform 0.2s cubic-bezier(.34,1.56,.64,1), box-shadow 0.2s;
        cursor: pointer;
    }

        .btn-save:hover {
            transform: translateY(-2px) scale(1.03);
            box-shadow: 0 8px 20px rgba(168,85,247,0.4);
            color: #fff;
        }

    .btn-cancel {
        background: #fff;
        color: #64748b;
        border: 1.5px solid #e2e8f0;
        border-radius: 12px;
        padding: 0.6rem 1.3rem;
        font-family: inherit;
        font-weight: 700;
        font-size: 0.92rem;
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        text-decoration: none;
        transition: all 0.2s;
    }

        .btn-cancel:hover {
            background: #f1f5f9;
            color: #1e2a3a;
            border-color: #cbd5e1;
        }

    @@keyframes fadeDown {
        from {
            opacity: 0;
            transform: translateY(-12px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(24px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<div class="page-wrap">
    <div class="container pb-5">

        <div class="page-topbar">
            <div class="page-title">Users</div>
            <div class="page-right">
                <div>@today</div>
                <div class="avatar-circle">@initials</div>
            </div>
        </div>

        <div class="section-head">
            <div class="section-left">
                <div class="section-icon"><i class="bi bi-shield-lock"></i></div>
                <div>
                    <h2 class="section-h2">Create Admin</h2>
                    <div class="section-sub">Admins can access everything in the system.</div>
                </div>
            </div>
            <a asp-action="Index" class="btn-back">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>

        <div class="row justify-content-center">
            <div class="col-12 col-lg-7">
                <div class="jobs-card">
                    <div class="jobs-card-header">
                        <div class="jobs-title">
                            <i class="bi bi-person-plus"></i>
                            <span>New Admin</span>
                        </div>
                        <div class="jobs-badge">Role: Admin</div>
                    </div>

                    <div class="card-form-body">
                        <form asp-action="CreateAdmin" method="post">
                            <div asp-validation-summary="All" class="text-danger mb-3" style="font-size:0.85rem; font-weight:600;"></div>

                            <!-- Identity -->
                            <div class="form-section-label">Identity</div>

                            <div class="mb-3">
                                <label asp-for="FullName" class="form-label-custom"></label>
                                <div class="input-group">
                                    <span class="input-group-text-custom"><i class="bi bi-person"></i></span>
                                    <input asp-for="FullName" class="form-control form-control-styled" placeholder="Full name" />
                                </div>
                                <span asp-validation-for="FullName" class="text-danger" style="font-size:0.8rem; font-weight:600;"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Email" class="form-label-custom"></label>
                                <div class="input-group">
                                    <span class="input-group-text-custom"><i class="bi bi-envelope"></i></span>
                                    <input asp-for="Email" class="form-control form-control-styled" placeholder="admin@email.com" autocomplete="email" />
                                </div>
                                <span asp-validation-for="Email" class="text-danger" style="font-size:0.8rem; font-weight:600;"></span>
                            </div>

                            <!-- Security -->
                            <div class="form-section-label">Security</div>

                            <div class="mb-3">
                                <label asp-for="TempPassword" class="form-label-custom">Temporary Password</label>
                                <div class="input-group">
                                    <span class="input-group-text-custom"><i class="bi bi-key"></i></span>
                                    <input asp-for="TempPassword" class="form-control form-control-styled" autocomplete="new-password" />
                                </div>
                                <div class="field-hint">
                                    <i class="bi bi-info-circle"></i>
                                    Must meet password rules (uppercase, lowercase, number, symbol).
                                </div>
                                <span asp-validation-for="TempPassword" class="text-danger" style="font-size:0.8rem; font-weight:600;"></span>
                            </div>

                            <hr class="form-divider">

                            <div class="d-flex gap-2 flex-wrap">
                                <button type="submit" class="btn-save">
                                    <i class="bi bi-save"></i> Create Admin
                                </button>
                                <a asp-action="Index" class="btn-cancel">
                                    <i class="bi bi-x"></i> Cancel
                                </a>
                            </div>

                        </form>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
